DATABASE_URL="postgresql://user:password@localhost:5432/frutifica"
JWT_SECRET="troque-por-uma-chave-secreta-longa-e-aleatoria"
JWT_EXPIRES_IN="7d"

# SMTP para emails de recuperação de senha
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_FROM="Frutifica <seu-email@gmail.com>"

# URL do frontend (para links nos emails)
FRONTEND_URL="https://sistemafrutifica.com"

# URL pública desta API (usada para registrar o webhook da Evolution)
PUBLIC_API_URL="https://api.sistemafrutifica.com"

# Evolution API (integração com WhatsApp)
EVOLUTION_API_URL="https://sua-evolution-api.com"
EVOLUTION_API_KEY="troque-pela-api-key-da-evolution"

# Segredo compartilhado com o serviço de cron externo (se usado) para
# autenticar chamadas a POST /api/whatsapp/send-reminder
CRON_SECRET="troque-por-um-segredo-aleatorio"

# Cloudinary (armazenamento das fotos de célula recebidas por WhatsApp)
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="seu-api-secret"

PORT="3001"
