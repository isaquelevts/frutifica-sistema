generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  plan               String   @default("free")
  maxCells           Int?     @map("max_cells")
  subscriptionStatus String?  @map("subscription_status")
  createdAt          DateTime @default(now()) @map("created_at")

  profiles    Profile[]
  cells       Cell[]
  reports     Report[]
  generations Generation[]
  members     Member[]
  invites     Invite[]

  @@map("organizations")
}

/// Convite tokenizado para auto-cadastro de líderes.
/// Substitui o link público /cadastro-lider/:orgId, que expunha o orgId
/// de forma permanente e não-revogável.
model Invite {
  id             String    @id @default(uuid()) @db.Uuid
  token          String    @unique
  organizationId String    @map("organization_id") @db.Uuid
  generationId   String?   @map("generation_id") @db.Uuid
  role           String    @default("leader")
  label          String?
  maxUses        Int?      @map("max_uses")
  uses           Int       @default(0)
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generation   Generation?  @relation(fields: [generationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("invites")
}

model WhatsappConfig {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @unique @map("organization_id") @db.Uuid
  instanceName   String?  @map("instance_name")
  groupJid       String?  @map("group_jid")
  groupName      String?  @map("group_name")
  active         Boolean  @default(false)
  connected      Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("whatsapp_config")
}

model Profile {
  id             String    @id @db.Uuid
  email          String    @unique
  name           String?
  passwordHash   String    @map("password_hash")
  roles          String[]
  cellId         String?   @map("cell_id") @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  birthday       String?
  resetToken     String?   @map("reset_token")
  resetTokenExp  DateTime? @map("reset_token_exp")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  cell         Cell?         @relation(fields: [cellId], references: [id], onDelete: SetNull)

  @@map("profiles")
}

model Cell {
  id                          String    @id @default(uuid()) @db.Uuid
  name                        String
  leaderName                  String?   @map("leader_name")
  leaderId                    String?   @map("leader_id") @db.Uuid
  leaderPhone                 String?   @map("leader_phone")
  targetAudience              String?   @map("target_audience")
  dayOfWeek                   String?   @map("day_of_week")
  time                        String?
  address                     String?
  active                      Boolean   @default(true)
  generationId                String?   @map("generation_id") @db.Uuid
  organizationId              String?   @map("organization_id") @db.Uuid
  whatsappNotificationsPaused Boolean   @default(false) @map("whatsapp_notifications_paused")
  lastWhatsappInboundAt       DateTime? @map("last_whatsapp_inbound_at")
  lastWhatsappOptOutPromptAt  DateTime? @map("last_whatsapp_opt_out_prompt_at")
  createdAt                   DateTime  @default(now()) @map("created_at")

  organization Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  generation   Generation?           @relation(fields: [generationId], references: [id], onDelete: SetNull)
  reports      Report[]
  profiles     Profile[]
  members      Member[]
  whatsappLeaderSession WhatsappLeaderSession?

  @@map("cells")
}

model Report {
  id             String   @id @default(uuid()) @db.Uuid
  cellId         String?  @map("cell_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  participants   Int?
  visitors       Int?
  date           String?
  happened       Boolean  @default(true)
  noReportReason String?  @map("no_report_reason")
  photoUrl       String?  @map("photo_url")
  createdAt      DateTime @default(now()) @map("created_at")

  cell         Cell?         @relation(fields: [cellId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@map("reports")
}

model WhatsappLeaderSession {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  cellId         String    @unique @map("cell_id") @db.Uuid
  phone          String
  step           String
  weekDate       String    @map("week_date")
  draftParticipants Int?   @map("draft_participants")
  draftVisitors     Int?   @map("draft_visitors")
  remindedAt     DateTime? @map("reminded_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  cell Cell @relation(fields: [cellId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@map("whatsapp_leader_sessions")
}

model Generation {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  color          String?   @default("#3B82F6")
  active         Boolean   @default(true)
  leaderId       String?   @map("leader_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cells        Cell[]
  invites      Invite[]

  @@map("generations")
}

model Member {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  cellId         String?   @map("cell_id") @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  phone          String?
  email          String?
  type           String?
  active         Boolean   @default(true)
  firstVisitDate String?   @map("first_visit_date")
  birthday       String?
  createdAt      DateTime  @default(now()) @map("created_at")

  cell         Cell?         @relation(fields: [cellId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@map("members")
}
